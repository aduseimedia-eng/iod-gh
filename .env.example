# ============================================================
# IOD Ghana Membership Database
# Environment Configuration Template
# ============================================================
# Copy this file to .env and update with your actual values

# Database Configuration
# Local PostgreSQL / pgAdmin connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iod_ghana
DB_USER=postgres
DB_PASSWORD='your_password_here'

# Railway / hosted PostgreSQL
# Prefer DATABASE_URL in production if Railway provides it.
# For local backup/sync scripts, use Railway's public Postgres URL here
# so your local app can still point to local Postgres with DB_HOST/DB_NAME.
DATABASE_URL=
DATABASE_PUBLIC_URL=
RAILWAY_DATABASE_PUBLIC_URL=
DB_SSL=true

# Server Configuration
PORT=3000
SESSION_SECRET='replace_with_at_least_32_random_characters'
CORS_ORIGIN='http://localhost:3000'
# Use SESSION_SAME_SITE=none in Railway when GitHub Pages calls the API.
SESSION_SAME_SITE=lax

# Admin Setup (used by server startup and setup_admin_table.js)
ADMIN_DEFAULT_USERNAME='admin'
ADMIN_DEFAULT_PASSWORD='replace_with_a_unique_temporary_password'
ADMIN_DEFAULT_EMAIL='admin@iodghana.org'

# ============================================================
# Instructions:
# 1. Copy this file: copy .env.example .env
# 2. Edit .env and replace 'your_password_here' with your 
#    actual PostgreSQL password
# 3. Never commit your .env file to version control
# ============================================================
