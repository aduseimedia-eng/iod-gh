{
  "name": "iod-ghana-database",
  "version": "1.0.0",
  "description": "Institute of Directors-Ghana Membership Database System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:check": "node scripts/check-db-connection.js",
    "setup-db": "node scripts/setup-database.js",
    "backup:railway": "node scripts/backup-railway-postgres.js",
    "sync:railway-to-local": "node scripts/backup-railway-postgres.js --sync-railway-to-local",
    "sync:local-to-railway": "node scripts/backup-railway-postgres.js --sync-local-to-railway",
    "sync:railway-to-local:with-admin": "node scripts/backup-railway-postgres.js --sync-railway-to-local --include-admin",
    "sync:local-to-railway:with-admin": "node scripts/backup-railway-postgres.js --sync-local-to-railway --include-admin",
    "sync:two-way:with-admin": "node scripts/backup-railway-postgres.js --sync-two-way --include-admin"
  },
  "keywords": [
    "database",
    "membership",
    "postgresql",
    "iod-ghana"
  ],
  "author": "IOD Ghana",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "multer": "^2.0.2",
    "pg": "^8.11.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
